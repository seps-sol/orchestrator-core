# Optional if you use `gh auth login`. Orchestrator calls `gh` with this token when set.
# https://cli.github.com/manual/gh_auth_login
GITHUB_TOKEN=
# gh also accepts GH_TOKEN (optional duplicate)
# GH_TOKEN=
GITHUB_ORG=seps-sol
# Repo whose Issues are scanned for label `seps:task`
# SEPS_TASKS_REPO=orchestrator-core
# Repo for orchestrator memory issues (label `seps:memory`); defaults to SEPS_TASKS_REPO
# SEPS_MEMORY_REPO=orchestrator-core

# LLM (set at least one; OpenAI recommended default)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default: gpt-5.4 via OpenAI when OPENAI_API_KEY is set
# SEPS_LLM_PROVIDER=openai
# SEPS_MODEL=gpt-5.4
